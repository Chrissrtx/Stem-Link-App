{
  "info": {
    "name": "STEM Link API",
    "description": "Colección completa de endpoints para el proyecto STEM Link - CS2031",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Perez\",\n  \"email\": \"juan@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\"\n}"
            }
          }
        },
        {
          "name": "Register Mentor",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ana Mentor\",\n  \"email\": \"mentor@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"MENTOR\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["const res = pm.response.json();", "if (res.token) { pm.collectionVariables.set('token', res.token); }"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get My User",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/users/me", "host": ["{{base_url}}"], "path": ["api","users","me"]}
          }
        }
      ]
    },
    {
      "name": "Mentors & Skills",
      "item": [
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{base_url}}/api/users/me/profile", "host": ["{{base_url}}"], "path": ["api","users","me","profile"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Estudiante de Ingeniería de Sistemas en UTEC\",\n  \"linkedinUrl\": \"https://linkedin.com/in/mentor\",\n  \"githubUrl\": \"https://github.com/mentor\",\n  \"videoCallUrl\": \"https://meet.google.com/abc-defg-hij\"\n}"
            }
          }
        },
        {
          "name": "Add Tags to Profile",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{base_url}}/api/users/me/tags", "host": ["{{base_url}}"], "path": ["api","users","me","tags"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"skillIds\": [1, 2, 3]\n}"
            }
          }
        },
        {
          "name": "List All Mentors",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{base_url}}/api/mentors",
              "host": ["{{base_url}}"],
              "path": ["api","mentors"],
              "query": [
                {"key": "name", "value": "", "disabled": true},
                {"key": "tag", "value": "", "disabled": true}
              ]
            }
          }
        },
        {
          "name": "Get Mentor by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/mentors/1", "host": ["{{base_url}}"], "path": ["api","mentors","1"]}
          }
        },
        {
          "name": "List All Tags",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/tags", "host": ["{{base_url}}"], "path": ["api","tags"]}
          }
        }
      ]
    },
    {
      "name": "Availability & Bookings",
      "item": [
        {
          "name": "Get Mentor Availability",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/mentors/1/availability", "host": ["{{base_url}}"], "path": ["api","mentors","1","availability"]}
          }
        },
        {
          "name": "Create Availability Block",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{base_url}}/api/mentors/me/availability", "host": ["{{base_url}}"], "path": ["api","mentors","me","availability"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dayOfWeek\": \"MONDAY\",\n  \"startTime\": \"10:00:00\",\n  \"endTime\": \"11:00:00\"\n}"
            }
          }
        },
        {
          "name": "Delete Availability Block",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/mentors/me/availability/1", "host": ["{{base_url}}"], "path": ["api","mentors","me","availability","1"]}
          }
        },
        {
          "name": "Create Booking (Session)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{base_url}}/api/sessions", "host": ["{{base_url}}"], "path": ["api","sessions"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mentorProfileId\": 1,\n  \"availabilityBlockId\": 1,\n  \"date\": \"2026-06-02\"\n}"
            }
          }
        },
        {
          "name": "Confirm Booking",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{base_url}}/api/sessions/1/status", "host": ["{{base_url}}"], "path": ["api","sessions","1","status"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{base_url}}/api/sessions/1/status", "host": ["{{base_url}}"], "path": ["api","sessions","1","status"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELLED\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Notifications & Feedback",
      "item": [
        {
          "name": "Get My Sessions",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{base_url}}/api/sessions",
              "host": ["{{base_url}}"],
              "path": ["api","sessions"],
              "query": [
                {"key": "status", "value": "PENDING", "disabled": true}
              ]
            }
          }
        },
        {
          "name": "Submit Feedback",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{base_url}}/api/sessions/1/feedback", "host": ["{{base_url}}"], "path": ["api","sessions","1","feedback"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stars\": 5,\n  \"mentorComments\": \"Excelente sesión, muy clara la explicación\",\n  \"impactRecord\": \"Aprendí sobre estructuras de datos\"\n}"
            }
          }
        },
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/notifications", "host": ["{{base_url}}"], "path": ["api","notifications"]}
          }
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/notifications/1/read", "host": ["{{base_url}}"], "path": ["api","notifications","1","read"]}
          }
        }
      ]
    }
  ]
}
